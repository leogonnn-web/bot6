{
  "dashboard": {
    "title": "HYDRA Trades Detail",
    "panels": [
      {
        "id": 1,
        "title": "Daily Profit by Symbol",
        "type": "table",
        "targets": [
          {
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "sqlite-trades"
            },
            "rawQuery": true,
            "rawSql": "SELECT date(timestamp, 'unixepoch') as Date, symbol as Symbol, COUNT(*) as Trades, SUM(CASE WHEN profit > 0 THEN 1 ELSE 0 END) as Wins, SUM(CASE WHEN profit < 0 THEN 1 ELSE 0 END) as Losses, ROUND(SUM(profit), 2) as Profit FROM trades WHERE side LIKE 'sell%' GROUP BY date(timestamp, 'unixepoch'), symbol ORDER BY Date DESC, Profit DESC",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "custom": {"displayMode": "color-background", "align": "auto"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 0}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Profit"},
              "properties": [
                {"id": "custom.displayMode", "value": "color-background"},
                {"id": "unit", "value": "currencyUSD"}
              ]
            }
          ]
        }
      },
      {
        "id": 2,
        "title": "Recent Trades",
        "type": "table",
        "targets": [
          {
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "sqlite-trades"
            },
            "rawQuery": true,
            "rawSql": "SELECT datetime(timestamp, 'unixepoch') as Time, symbol as Symbol, side as Side, ROUND(price, 6) as Price, ROUND(profit, 2) as Profit FROM trades WHERE side LIKE 'sell%' ORDER BY timestamp DESC LIMIT 50",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 10},
        "fieldConfig": {
          "defaults": {
            "custom": {"displayMode": "color-background", "align": "auto"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 0}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Profit"},
              "properties": [
                {"id": "custom.displayMode", "value": "color-background"},
                {"id": "unit", "value": "currencyUSD"}
              ]
            }
          ]
        }
      }
    ],
    "schemaVersion": 36,
    "version": 1
  },
  "overwrite": true
}
